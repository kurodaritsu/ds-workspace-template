{
    "name": "${localWorkspaceFolderBasename}-devcontainer",
    "dockerComposeFile": "../.devcontainer/docker-compose.yml",
    "service": "vscode",
    "remoteUser": "vscode",
    "runServices": [
        "vscode"
    ],
    "workspaceFolder": "/workspace",
    "mounts": [
        {
            "source": "cache-${devcontainerId}",
            "target": "/home/${remoteUser}/.cache",
            "type": "volume"
        },
        {
            "source": "${localEnv:HOME}/.ssh",
            "target": "/home/${remoteUser}/.ssh",
            "type": "bind"
        },
        {
            "source": "venv-${devcontainerId}",
            "target": "${containerWorkspaceFolder}/.venv",
            "type": "volume"
        }
    ],
    "updateContentCommand": "sudo chown -R vscode /home/vscode/.cache /home/vscode/.ssh ${containerWorkspaceFolder}/.venv",
    "postCreateCommand": "uv sync",
    "containerEnv": {
        "PYTHONPATH": "${containerWorkspaceFolder}",
        "UV_PROJECT_ENVIRONMENT": "${containerWorkspaceFolder}/.venv",
        "JUPYTER_DATA_DIR": "${containerWorkspaceFolder}",
        "UV_COMPILE_BYTECODE": "1",
        "PYTHONUNBUFFERED": "True",
        "UV_LINK_MODE": "copy"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-toolsai.jupyter",
                "ms-python.python",
                "charliermarsh.ruff",
                "redhat.vscode-yaml",
                "tamasfe.even-better-toml",
                "astral-sh.ty",
                "njpwerner.autodocstring"
            ]
        }
    }
}
